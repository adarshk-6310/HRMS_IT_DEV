@model HRMS_IT.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
}
@{
    Layout = "~/Views/Shared/_LeftLayout.cshtml";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card mt-5 shadow">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h4 class="mb-0">Sign In</h4>
                </div>

                <div class="card-body p-4">

                    <form asp-action="Login" asp-controller="HomeController" method="post" class="needs-validation" novalidate>
                        <input type="hidden" asp-for="ReturnUrl"/>
                        <div class="mb-3">
                            <label asp-for="UserNameOrEmail" class="form-label"></label>
                            <input asp-for="UserNameOrEmail" class="form-control" placeholder="Username or email address" autofocus />
                            <span asp-validation-for="UserNameOrEmail" class="text-danger small"></span>

                        </div>
                        <div class="mb-3">
                            <label asp-for="Password" class="form-label"></label>
                            <input asp-for="Password" class="form-control" placeholder="......." />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        <div class="d-flex justify-content-between align-items mb-4">
                            <div class="form-check">
                                <input asp-for="RememberMe" class="form-check-input" type="checkbox" />
                                <label asp-for="RememberMe" class="form-check-label"></label>
                            </div>
                            <a asp-action="ForgotPassword" asp-controller="Account" class="small text-muted">Forgot password?</a>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 py-2"> Sign In </button>

                    </form>




                    <hr class="my-4" />

                    <div class="text-center">
                        <small>
                            Don't have an account?
                            <a asp-action="Register" asp-controller="Account">Create one</a>
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

