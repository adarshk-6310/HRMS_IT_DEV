@model Models.Payroll.SalaryStructure

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <style>
        body {
            font-family: Arial;
            font-size: 14px;
        }

        .container {
            width: 700px;
            margin: auto;
            border: 1px solid #000;
            padding: 20px;
        }

        .header {
            text-align: center;
        }

        .logo {
            height: 60px;
        }

        .title {
            font-size: 20px;
            font-weight: bold;
        }

        .section {
            margin-top: 20px;
        }

        .table {
            width: 100%;
            border-collapse: collapse;
        }

        .table, .table th, .table td {
            border: 1px solid #000;
        }

        .table th, .table td {
            padding: 8px;
            text-align: left;
        }

        .text-right {
            text-align: right;
        }

        .net {
            font-size: 16px;
            font-weight: bold;
        }

    </style>
</head>
<body>

<div class="container">

    <!-- HEADER -->
    <div class="header">
        <img src="~/images/logo.png" class="logo" />
        <div class="title">Your Company Pvt Ltd</div>
        <div>Salary Slip</div>
    </div>

    <!-- EMPLOYEE DETAILS -->
    <div class="section">
        <table class="table">
            <tr>
                <td><b>Employee Name</b></td>
                <td>@Model.EmployeeName</td>
                <td><b>Month</b></td>
                <td>@Model.SalaryMonth.ToString("MMMM yyyy")</td>
            </tr>
        </table>
    </div>

    <!-- SALARY DETAILS -->
    <div class="section">
        <table class="table">
            <thead>
                <tr>
                    <th>Earnings</th>
                    <th class="text-right">Amount</th>
                    <th>Deductions</th>
                    <th class="text-right">Amount</th>
                </tr>
            </thead>

            <tbody>
                <tr>
                    <td>Basic Salary</td>
                    <td class="text-right">@Model.BasicSalary</td>
                    <td>Deductions</td>
                    <td class="text-right">@Model.Deductions</td>
                </tr>

                <tr>
                    <td>HRA</td>
                    <td class="text-right">@Model.HRA</td>
                    <td></td>
                    <td></td>
                </tr>

                <tr>
                    <td>Allowances</td>
                    <td class="text-right">@Model.Allowances</td>
                    <td></td>
                    <td></td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- NET SALARY -->
    <div class="section net">
        Net Salary: ₹ @Model.NetSalary
    </div>

    <!-- FOOTER -->
    <div class="section">
        <p>This is a system-generated payslip and does not require signature.</p>
    </div>

</div>

</body>
</html>