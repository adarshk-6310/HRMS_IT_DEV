@model Models.Payroll.SalaryStructure

<div class="container">
    <h2>Add Payroll</h2>

    <form method="post">

        <div class="row">

            <div class="col-md-6 mb-3">
                <label>Employee</label>
                <select asp-for="EmployeeId" class="form-control">
                    <option value="">-- Select Employee --</option>
                    @foreach (var emp in ViewBag.Employees)
                    {
                        <option value="@emp.Id">@emp.Name</option>
                    }
                </select>
            </div>

            <div class="col-md-6 mb-3">
                <label>Basic Salary</label>
                <input asp-for="BasicSalary" class="form-control" id="basic" />
            </div>

            <div class="col-md-6 mb-3">
                <label>HRA</label>
                <input asp-for="HRA" class="form-control" id="hra" />
            </div>

            <div class="col-md-6 mb-3">
                <label>Allowances</label>
                <input asp-for="Allowances" class="form-control" id="allow" />
            </div>

            <div class="col-md-6 mb-3">
                <label>Deductions</label>
                <input asp-for="Deductions" class="form-control" id="ded" />
            </div>

            <div class="col-md-6 mb-3">
                <label>Net Salary</label>
                <input asp-for="NetSalary" class="form-control" id="net" readonly />
            </div>

            <div class="col-md-6 mb-3">
                <label>Salary Month</label>
                <input asp-for="SalaryMonth" type="month" class="form-control" />
            </div>

        </div>

        <button class="btn btn-success">Save</button>
        <a href="/Payroll" class="btn btn-secondary">Back</a>

    </form>
</div>

<script>
    function calculate() {
        let basic = parseFloat(document.getElementById("basic").value) || 0;
        let hra = parseFloat(document.getElementById("hra").value) || 0;
        let allow = parseFloat(document.getElementById("allow").value) || 0;
        let ded = parseFloat(document.getElementById("ded").value) || 0;

        document.getElementById("net").value = basic + hra + allow - ded;
    }

    document.querySelectorAll("#basic, #hra, #allow, #ded")
        .forEach(el => el.addEventListener("input", calculate));
</script>